<Window x:Class="EcclesiaCast.App.Views.YouTubeBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="YouTube — buscar y conectar tu cuenta"
        Width="1100" Height="760"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="➕ Agregar este video" Style="{StaticResource AccentButton}"
                            Click="AddCurrent_Click" Padding="14,7"
                            ToolTip="Agrega el video que estás viendo a la pestaña YouTube"/>
                    <Button Content="Cerrar" Style="{StaticResource DarkButton}" IsCancel="True"
                            Padding="14,7" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="◀" Style="{StaticResource DarkButton}" Padding="10,7" Click="Back_Click"/>
                    <Button Content="▶" Style="{StaticResource DarkButton}" Padding="10,7" Margin="4,0,0,0" Click="Forward_Click"/>
                    <Button Content="🏠" Style="{StaticResource DarkButton}" Padding="10,7" Margin="4,0,8,0" Click="Home_Click"/>
                </StackPanel>
                <TextBlock Text="Iniciá sesión con tu cuenta (Premium reproduce sin anuncios). La sesión queda guardada."
                           FontSize="11" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <wv2:WebView2 x:Name="Browser" DefaultBackgroundColor="Black"/>
    </DockPanel>
</Window>
