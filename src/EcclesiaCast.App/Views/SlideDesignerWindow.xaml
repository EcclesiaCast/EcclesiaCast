<Window x:Class="EcclesiaCast.App.Views.SlideDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diseño de diapositiva"
        Width="1300" Height="660"
        MinWidth="1100" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,14,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="290"/>
        </Grid.ColumnDefinitions>

        <!-- ── Lienzo (1920×1080 a mitad de escala) ── -->
        <Border Grid.Column="0" Background="#0B0D12" CornerRadius="6"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid x:Name="CanvasRoot" Width="960" Height="540" ClipToBounds="True">
                    <Grid x:Name="BackgroundHost" Background="#10141E">
                        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                        <Rectangle x:Name="DimLayer" Fill="Black" Opacity="0"/>
                    </Grid>
                    <Canvas x:Name="DesignCanvas" Background="Transparent">
                        <Border x:Name="BoxBorder"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1.5"
                                Background="#152F63C9"
                                Cursor="SizeAll"
                                MouseLeftButtonDown="Box_MouseDown"
                                MouseMove="Box_MouseMove"
                                MouseLeftButtonUp="Box_MouseUp">
                            <Grid>
                                <TextBlock x:Name="BoxText"
                                           TextWrapping="Wrap"
                                           Foreground="White"
                                           Margin="6"/>
                                <Thumb x:Name="ResizeThumb"
                                       Width="16" Height="16"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       DragDelta="ResizeThumb_DragDelta">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </Border>
                    </Canvas>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Panel de formato ── -->
        <DockPanel Grid.Column="2">
            <StackPanel DockPanel.Dock="Bottom">
                <TextBlock Text="Arrastrá la caja para moverla · esquina inferior derecha para cambiar el tamaño."
                           FontSize="11" Foreground="{StaticResource FaintBrush}"
                           TextWrapping="Wrap" Margin="0,10,0,12"/>
                <Button Content="Restablecer (usar el tema tal cual)"
                        Style="{StaticResource DarkButton}"
                        Click="Reset_Click" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Guardar" Style="{StaticResource AccentButton}"
                            Click="Save_Click" Padding="0,9"/>
                    <Button Grid.Column="2" Content="Cancelar" Style="{StaticResource DarkButton}"
                            IsCancel="True" Padding="0,9"/>
                </Grid>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="DISEÑO DE ESTA DIAPOSITIVA" Style="{StaticResource PanelTitle}" Margin="0,0,0,2"/>
                    <TextBlock Text="Solo afecta esta diapositiva; el resto de la canción sigue el tema."
                               FontSize="11" Foreground="{StaticResource FaintBrush}" TextWrapping="Wrap"/>

                    <TextBlock Style="{StaticResource FieldLabel}">
                        <Run Text="Tamaño de letra: "/><Run x:Name="FontSizeValue" Text="92"/>
                    </TextBlock>
                    <Slider x:Name="FontSizeSlider" Minimum="24" Maximum="160"
                            ValueChanged="Style_Changed"/>

                    <TextBlock Text="Estilo" Style="{StaticResource FieldLabel}"/>
                    <WrapPanel>
                        <CheckBox x:Name="BoldCheck" Content="Negrita" Checked="Style_Changed" Unchecked="Style_Changed"/>
                        <CheckBox x:Name="ItalicCheck" Content="Cursiva" Checked="Style_Changed" Unchecked="Style_Changed"/>
                    </WrapPanel>

                    <TextBlock Text="Color del texto (hex)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="ColorBox"
                             Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                             BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                             Padding="6,4" FontSize="12"
                             TextChanged="Style_Changed"/>

                    <TextBlock Text="Alineación horizontal" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="AlignHCombo" FontSize="12" SelectionChanged="Style_Changed">
                        <ComboBoxItem Content="Izquierda"/>
                        <ComboBoxItem Content="Centro"/>
                        <ComboBoxItem Content="Derecha"/>
                    </ComboBox>

                    <TextBlock Text="Alineación vertical (dentro de la caja)" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="AlignVCombo" FontSize="12" SelectionChanged="Style_Changed">
                        <ComboBoxItem Content="Arriba"/>
                        <ComboBoxItem Content="Centro"/>
                        <ComboBoxItem Content="Abajo"/>
                    </ComboBox>

                    <TextBlock Text="Posición y tamaño de la caja" Style="{StaticResource FieldLabel}"/>
                    <TextBlock x:Name="BoxInfo" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
