<Window x:Class="EcclesiaCast.App.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elegir color"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Preview + hex -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <Border x:Name="Preview" DockPanel.Dock="Left" Width="56" Height="56" CornerRadius="6"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Background="White"/>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Código (hex)" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                <TextBox x:Name="HexBox" Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                         BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                         Padding="6,4" FontSize="13" TextChanged="Hex_Changed"/>
            </StackPanel>
        </DockPanel>

        <!-- Paleta de colores frecuentes -->
        <TextBlock Grid.Row="1" Text="Colores frecuentes" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
        <ItemsControl Grid.Row="2" x:Name="Swatches" Margin="0,0,0,14">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="30" Height="30" Margin="3" Cursor="Hand"
                            Click="Swatch_Click" Tag="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{Binding}" CornerRadius="4"
                                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Sliders RGB -->
        <StackPanel Grid.Row="3">
            <DockPanel Margin="0,0,0,4">
                <TextBlock Text="R" DockPanel.Dock="Left" Width="16" Foreground="#E06666" FontWeight="SemiBold"/>
                <TextBlock x:Name="RValue" DockPanel.Dock="Right" Width="34" TextAlignment="Right" Foreground="White"/>
                <Slider x:Name="RSlider" Minimum="0" Maximum="255" ValueChanged="Rgb_Changed"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,4">
                <TextBlock Text="G" DockPanel.Dock="Left" Width="16" Foreground="#6FBF8F" FontWeight="SemiBold"/>
                <TextBlock x:Name="GValue" DockPanel.Dock="Right" Width="34" TextAlignment="Right" Foreground="White"/>
                <Slider x:Name="GSlider" Minimum="0" Maximum="255" ValueChanged="Rgb_Changed"/>
            </DockPanel>
            <DockPanel>
                <TextBlock Text="B" DockPanel.Dock="Left" Width="16" Foreground="#7CA4EF" FontWeight="SemiBold"/>
                <TextBlock x:Name="BValue" DockPanel.Dock="Right" Width="34" TextAlignment="Right" Foreground="White"/>
                <Slider x:Name="BSlider" Minimum="0" Maximum="255" ValueChanged="Rgb_Changed"/>
            </DockPanel>
        </StackPanel>

        <DockPanel Grid.Row="4" Margin="0,16,0,0">
            <Button x:Name="TransparentButton" DockPanel.Dock="Left"
                    Content="Transparente" Style="{StaticResource DarkButton}"
                    Click="Transparent_Click" Padding="14,8"
                    Visibility="Collapsed"
                    ToolTip="Sin color de fondo: se verá el video/imagen detrás"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Aceptar" Style="{StaticResource AccentButton}" Click="Accept_Click" Padding="20,8"/>
                <Button Content="Cancelar" Style="{StaticResource DarkButton}" IsCancel="True" Padding="20,8" Margin="8,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
