<Window x:Class="EcclesiaCast.App.Views.QuickTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edición rápida"
        Width="520" Height="320"
        MinWidth="380" MinHeight="240"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Corregí el texto de esta diapositiva (solo el texto — el formato no cambia)."
                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="TextBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                 BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                 Padding="10,8" FontSize="15"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Guardar" Style="{StaticResource AccentButton}" Click="Save_Click" Padding="20,8"/>
            <Button Content="Cancelar" Style="{StaticResource DarkButton}" IsCancel="True" Padding="20,8" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
