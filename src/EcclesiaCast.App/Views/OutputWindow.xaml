<Window x:Class="EcclesiaCast.App.Views.OutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EcclesiaCast.App.Controls"
        Title="EcclesiaCast — Salida"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Topmost="True"
        Cursor="None"
        Background="Black">
    <Grid>
        <!-- Video de fondo (frames a WriteableBitmap), detrás de todo -->
        <controls:VlcVideoSurface x:Name="Video"/>

        <!-- Fondo de imagen + texto + estados, compuesto encima -->
        <controls:ProjectedView x:Name="Projected"
                                Slide="{Binding Slide}"
                                State="{Binding State}"
                                Overlay="{Binding Overlay}"
                                Highlight="{Binding Highlight}"
                                BackgroundMedia="{Binding Background}"
                                IsLiveOutput="True"
                                AnimateTransitions="True"/>
    </Grid>
</Window>
