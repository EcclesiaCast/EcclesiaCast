<Window x:Class="EcclesiaCast.App.Views.OutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EcclesiaCast.App.Controls"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="EcclesiaCast — Salida"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Topmost="True"
        Cursor="None"
        Background="Black">
    <!-- The WPF VideoView renders the video in its own airspace and overlays
         its Content (image background + text) on top, avoiding the classic
         WPF-over-native compositing problem. -->
    <vlc:VideoView x:Name="Video" Background="Black">
        <controls:ProjectedView x:Name="Projected"
                                Slide="{Binding Slide}"
                                State="{Binding State}"
                                Overlay="{Binding Overlay}"
                                Highlight="{Binding Highlight}"
                                BackgroundMedia="{Binding Background}"
                                IsLiveOutput="True"
                                AnimateTransitions="True"/>
    </vlc:VideoView>
</Window>
