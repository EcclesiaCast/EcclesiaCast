<Window x:Class="EcclesiaCast.App.Views.OutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EcclesiaCast.App.Controls"
        Title="EcclesiaCast — Salida"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="None"
        Background="Black"
        KeyDown="OnKeyDown">
    <controls:SlideView Slide="{Binding Slide}"
                        State="{Binding State}"
                        Overlay="{Binding Overlay}"
                        AnimateTransitions="True"/>
</Window>
