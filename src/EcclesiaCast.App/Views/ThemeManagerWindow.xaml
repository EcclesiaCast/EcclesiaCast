<Window x:Class="EcclesiaCast.App.Views.ThemeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EcclesiaCast.App.Controls"
        Title="Temas de proyección"
        Width="1020" Height="760"
        MinWidth="880" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBox" x:Key="Field">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,14,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Lista de temas ── -->
        <Border Grid.Column="0" Style="{StaticResource Panel}">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,8,10,6">
                        <Button Content="➕" FontSize="11" Padding="6,3"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding NewThemeCommand}" ToolTip="Nuevo tema"/>
                        <Button Content="⧉" FontSize="11" Padding="6,3" Margin="4,0,0,0"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding DuplicateThemeCommand}" ToolTip="Duplicar tema"/>
                        <Button Content="🗑" FontSize="11" Padding="6,3" Margin="4,0,0,0"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding DeleteThemeCommand}" ToolTip="Eliminar tema"/>
                    </StackPanel>
                    <TextBlock Text="TEMAS" Style="{StaticResource PanelTitle}"/>
                </DockPanel>
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding DefaultsText}"
                           FontSize="10" Foreground="{StaticResource FaintBrush}"
                           TextWrapping="Wrap" Margin="12,4,12,10"/>
                <ListBox ItemsSource="{Binding Themes}"
                         SelectedItem="{Binding SelectedTheme}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="4"
                                                Margin="6,1" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#20242F"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Editor + vista previa ── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Vista previa con caja arrastrable -->
            <Border Grid.Row="0" Background="#0B0D12" CornerRadius="6"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                    Height="280" Margin="0,0,0,10">
                <Viewbox Stretch="Uniform" Margin="6">
                    <Grid Width="960" Height="540" ClipToBounds="True">
                        <controls:SlideView Slide="{Binding PreviewSlide}"/>
                        <Canvas x:Name="Overlay" Background="Transparent">
                            <Border x:Name="BoxBorder"
                                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5"
                                    Background="#11FFFFFF" Cursor="SizeAll"
                                    Focusable="True"
                                    MouseLeftButtonDown="Box_MouseDown"
                                    MouseMove="Box_MouseMove"
                                    MouseLeftButtonUp="Box_MouseUp"
                                    PreviewKeyDown="Box_KeyDown"
                                    ToolTip="Arrastrá para mover · manijas para el tamaño · flechas para ajuste fino">
                                <Grid>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="NW" Cursor="SizeNWSE"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="N" Cursor="SizeNS"
                                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-6,0,0" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="NE" Cursor="SizeNESW"
                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-6" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="W" Cursor="SizeWE"
                                           HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-6,0,0,0" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="E" Cursor="SizeWE"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-6,0" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="SW" Cursor="SizeNESW"
                                           HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-6" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="S" Cursor="SizeNS"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-6" DragDelta="Handle_DragDelta"/>
                                    <Thumb Style="{StaticResource BoxHandle}" Tag="SE" Cursor="SizeNWSE"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="-6" DragDelta="Handle_DragDelta"/>
                                </Grid>
                            </Border>
                        </Canvas>
                    </Grid>
                </Viewbox>
            </Border>

            <!-- Campos -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="2,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Columna izquierda: texto -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nombre del tema" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding ThemeName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Tipo" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedIndex="{Binding KindIndex}" FontSize="12">
                            <ComboBoxItem Content="Canciones"/>
                            <ComboBoxItem Content="Biblia"/>
                        </ComboBox>

                        <TextBlock Text="Tipografía" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FontCombo" IsEditable="True" FontSize="12"
                                  Text="{Binding FontFamily, UpdateSourceTrigger=LostFocus}"/>

                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="Tamaño máximo: "/><Run Text="{Binding MaxFontSize, StringFormat={}{0:0}}"/>
                        </TextBlock>
                        <Slider Minimum="30" Maximum="160" Value="{Binding MaxFontSize}"/>

                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="Tamaño mínimo (auto-ajuste): "/><Run Text="{Binding MinFontSize, StringFormat={}{0:0}}"/>
                        </TextBlock>
                        <Slider Minimum="16" Maximum="100" Value="{Binding MinFontSize}"/>

                        <TextBlock Text="Estilo" Style="{StaticResource FieldLabel}"/>
                        <WrapPanel>
                            <CheckBox Content="Negrita" IsChecked="{Binding Bold}"/>
                            <CheckBox Content="Cursiva" IsChecked="{Binding Italic}"/>
                            <CheckBox Content="Mayúsculas" IsChecked="{Binding Uppercase}"/>
                            <CheckBox Content="Sombra" IsChecked="{Binding Shadow}"/>
                        </WrapPanel>

                        <TextBlock Text="Color del texto" Style="{StaticResource FieldLabel}"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Paleta…" FontSize="11" Padding="8,3" Margin="6,0,0,0"
                                    Style="{StaticResource DarkButton}" Command="{Binding PickTextColorCommand}"/>
                            <TextBox Style="{StaticResource Field}" Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Alineación horizontal" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedIndex="{Binding AlignHIndex}" FontSize="12">
                            <ComboBoxItem Content="Izquierda"/>
                            <ComboBoxItem Content="Centro"/>
                            <ComboBoxItem Content="Derecha"/>
                        </ComboBox>

                        <TextBlock Text="Alineación vertical" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedIndex="{Binding AlignVIndex}" FontSize="12">
                            <ComboBoxItem Content="Arriba"/>
                            <ComboBoxItem Content="Centro"/>
                            <ComboBoxItem Content="Abajo"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Columna derecha: fondo y leyenda -->
                    <StackPanel Grid.Column="2">
                        <CheckBox Content="Ajustar a una línea" IsChecked="{Binding FitToWidth}" Margin="0,10,0,0"
                                  ToolTip="Achica el texto hasta que cada renglón entre en una sola línea"/>
                        <TextBlock Text="La caja de texto se ajusta arrastrándola en la vista previa de arriba."
                                   FontSize="11" Foreground="{StaticResource FaintBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>

                        <CheckBox Content="Fondo transparente (para poner video/imagen detrás)"
                                  IsChecked="{Binding TransparentBackground}" Margin="0,10,0,0"/>

                        <TextBlock Text="Color de fondo" Style="{StaticResource FieldLabel}"/>
                        <DockPanel IsEnabled="{Binding TransparentBackground, Converter={StaticResource InverseBool}}">
                            <Button DockPanel.Dock="Right" Content="Paleta…" FontSize="11" Padding="8,3" Margin="6,0,0,0"
                                    Style="{StaticResource DarkButton}" Command="{Binding PickBackgroundColorCommand}"/>
                            <TextBox Style="{StaticResource Field}" Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Imagen de fondo" Style="{StaticResource FieldLabel}"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" FontSize="11" Padding="7,3" Margin="4,0,0,0"
                                    Style="{StaticResource DarkButton}"
                                    Command="{Binding ClearBackgroundImageCommand}" ToolTip="Quitar imagen"/>
                            <Button DockPanel.Dock="Right" Content="Examinar…" FontSize="11" Padding="8,3" Margin="6,0,0,0"
                                    Style="{StaticResource DarkButton}"
                                    Command="{Binding BrowseBackgroundImageCommand}"/>
                            <TextBox Style="{StaticResource Field}" IsReadOnly="True"
                                     Text="{Binding BackgroundImagePath, Mode=OneWay}"/>
                        </DockPanel>

                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="Oscurecedor del fondo: "/><Run Text="{Binding BackgroundDimPercent, StringFormat={}{0:0} %}"/>
                        </TextBlock>
                        <Slider Minimum="0" Maximum="100" Value="{Binding BackgroundDimPercent}"/>

                        <TextBlock Text="Leyenda (canciones: título y artista · Biblia: referencia)" Style="{StaticResource FieldLabel}"/>
                        <CheckBox Content="Mostrar leyenda" IsChecked="{Binding ShowCaption}"/>

                        <TextBlock Text="Posición de la leyenda" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedIndex="{Binding CaptionPositionIndex}" FontSize="12">
                            <ComboBoxItem Content="Arriba a la izquierda"/>
                            <ComboBoxItem Content="Arriba al centro"/>
                            <ComboBoxItem Content="Arriba a la derecha"/>
                            <ComboBoxItem Content="Abajo a la izquierda"/>
                            <ComboBoxItem Content="Abajo al centro"/>
                            <ComboBoxItem Content="Abajo a la derecha"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="Tamaño de la leyenda: "/><Run Text="{Binding CaptionFontSize, StringFormat={}{0:0}}"/>
                        </TextBlock>
                        <Slider Minimum="20" Maximum="70" Value="{Binding CaptionFontSize}"/>

                        <StackPanel Visibility="{Binding IsBibleKind, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Solo Biblia" Style="{StaticResource FieldLabel}"/>
                            <WrapPanel>
                                <CheckBox Content="Mostrar versión en la referencia" IsChecked="{Binding ShowVersionName}"/>
                                <CheckBox Content="Número de versículo en el texto" IsChecked="{Binding ShowVerseNumbers}"/>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Acciones -->
            <DockPanel Grid.Row="2" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Usar en canciones" Style="{StaticResource DarkButton}"
                            Command="{Binding SetDefaultForSongsCommand}"
                            ToolTip="Este tema pasa a ser el predeterminado de las canciones"/>
                    <Button Content="Usar en Biblia" Style="{StaticResource DarkButton}" Margin="6,0,0,0"
                            Command="{Binding SetDefaultForBibleCommand}"
                            ToolTip="Este tema pasa a ser el que usa toda la Biblia"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Button Content="Guardar tema" Style="{StaticResource AccentButton}"
                            Command="{Binding SaveThemeCommand}" Padding="18,8"/>
                    <Button Content="Cerrar" Style="{StaticResource DarkButton}" Margin="8,0,0,0"
                            Padding="18,8" IsCancel="True"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
