<Window x:Class="EcclesiaCast.App.Views.MediaInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Propiedades del medio"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="L">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <DockPanel>
                <Border DockPanel.Dock="Left" Width="120" Height="68" CornerRadius="4"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" ClipToBounds="True">
                    <Image x:Name="Poster" Stretch="UniformToFill"/>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Nombre" Style="{StaticResource L}" Margin="0,0,0,3"/>
                    <TextBox x:Name="NameBox" Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                             BorderBrush="{StaticResource LineBrush}" CaretBrush="White" Padding="6,4" FontSize="13"/>
                    <TextBlock x:Name="TypeText" FontSize="11" Foreground="{StaticResource FaintBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </DockPanel>

            <TextBlock Text="Pestaña" Style="{StaticResource L}"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True"/>

            <TextBlock Text="Comportamiento" Style="{StaticResource L}"/>
            <ComboBox x:Name="BehaviorBox">
                <ComboBoxItem Content="Fondo (detrás del texto, en bucle)"/>
                <ComboBoxItem Content="Primer plano (pantalla completa, tapa el texto)"/>
            </ComboBox>

            <TextBlock Text="Escala (si no es 16:9)" Style="{StaticResource L}"/>
            <ComboBox x:Name="ScalingBox">
                <ComboBoxItem Content="Rellenar (recorta lo que sobra)"/>
                <ComboBoxItem Content="Ajustar (todo, con barras)"/>
                <ComboBoxItem Content="Estirar (deforma)"/>
            </ComboBox>

            <StackPanel x:Name="VideoOptions">
                <TextBlock Text="Al terminar el video" Style="{StaticResource L}"/>
                <ComboBox x:Name="EndBox">
                    <ComboBoxItem Content="Repetir en bucle"/>
                    <ComboBoxItem Content="Detener al final"/>
                </ComboBox>

                <CheckBox x:Name="MuteCheck" Content="Silenciar audio" Margin="0,14,0,0"/>
                <TextBlock Style="{StaticResource L}">
                    <Run Text="Volumen: "/><Run x:Name="VolValue" Text="100"/>
                </TextBlock>
                <Slider x:Name="VolSlider" Minimum="0" Maximum="100" ValueChanged="Vol_Changed"/>
            </StackPanel>

            <Button Content="📂 Abrir ubicación del archivo" Style="{StaticResource DarkButton}"
                    Click="OpenLocation_Click" Margin="0,16,0,0" HorizontalAlignment="Left" Padding="12,6"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Guardar" Style="{StaticResource AccentButton}" Click="Save_Click" Padding="20,8"/>
            <Button Content="Cancelar" Style="{StaticResource DarkButton}" IsCancel="True" Padding="20,8" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
