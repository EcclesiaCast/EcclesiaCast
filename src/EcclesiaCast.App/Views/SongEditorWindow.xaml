<Window x:Class="EcclesiaCast.App.Views.SongEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Canción"
        Width="680" Height="680"
        MinWidth="520" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Título *" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="TitleBox"
                     Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                     BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                     Padding="8,6" FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Artista" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="ArtistBox"
                         Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                         BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                         Padding="8,6" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Copyright / CCLI" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="CopyrightBox"
                         Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                         BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                         Padding="8,6" FontSize="14"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Text="Letra *" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="3"
                   FontSize="11" Foreground="{StaticResource FaintBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,6"
                   Text="Cada párrafo es una diapositiva: separá las diapositivas con una línea en blanco. Opcional: una línea [Coro] o [Verso 1] no se proyecta, solo le pone nombre a los párrafos que siguen."/>

        <TextBox Grid.Row="4"
                 x:Name="LyricsBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="{StaticResource SurfaceAltBrush}" Foreground="White"
                 BorderBrush="{StaticResource LineBrush}" CaretBrush="White"
                 Padding="10,8" FontSize="14"/>

        <DockPanel Grid.Row="5" Margin="0,16,0,0">
            <TextBlock x:Name="ErrorText"
                       Foreground="#E08A8A" FontSize="12"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Style="{StaticResource DarkButton}"
                        IsCancel="True"
                        Padding="18,9"/>
                <Button Content="Guardar"
                        Style="{StaticResource AccentButton}"
                        Click="Save_Click"
                        IsDefault="False"
                        Padding="18,9" Margin="10,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
