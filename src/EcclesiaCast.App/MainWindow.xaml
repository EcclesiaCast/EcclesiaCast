<Window x:Class="EcclesiaCast.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcclesiaCast — Operador"
        Width="600" Height="400"
        MinWidth="480" MinHeight="340"
        WindowStartupLocation="CenterScreen"
        Background="#14161C"
        FontFamily="Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ProjectTestCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding HideOutputCommand}"/>
    </Window.InputBindings>
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="EcclesiaCast"
                       FontSize="26" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Sprint 0 · Control de pantallas"
                       FontSize="13" Foreground="#9AA1B2" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,26,0,0">
            <TextBlock Text="Pantalla de salida"
                       FontSize="12" Foreground="#9AA1B2" Margin="0,0,0,6"/>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Actualizar"
                        Command="{Binding RefreshDisplaysCommand}"
                        Padding="12,6" Margin="8,0,0,0"/>
                <ComboBox ItemsSource="{Binding Displays}"
                          SelectedItem="{Binding SelectedDisplay}"
                          DisplayMemberPath="Label"
                          Padding="8,6"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="Proyectar prueba  (F1)"
                    Command="{Binding ProjectTestCommand}"
                    Background="#2F63C9" Foreground="White"
                    BorderThickness="0"
                    Padding="18,10" FontSize="14"/>
            <Button Content="Ocultar salida  (Esc)"
                    Command="{Binding HideOutputCommand}"
                    Padding="18,10" FontSize="14" Margin="10,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusText}"
                   FontSize="12" Foreground="#9AA1B2"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>
