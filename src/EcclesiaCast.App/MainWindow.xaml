<Window x:Class="EcclesiaCast.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EcclesiaCast.App.Controls"
        Title="EcclesiaCast — Operador"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ToggleClearCommand}"/>
        <KeyBinding Key="F2" Command="{Binding ToggleBlackCommand}"/>
        <KeyBinding Key="F3" Command="{Binding ToggleLogoCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding HideOutputCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Barra superior ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,9">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="EcclesiaCast"
                           FontSize="17" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="24,0,0,0">
                    <Button Content="Clear  (F1)" Command="{Binding ToggleClearCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsClearActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Black  (F2)" Command="{Binding ToggleBlackCommand}" Margin="6,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBlackActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Logo  (F3)" Command="{Binding ToggleLogoCommand}" Margin="6,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLogoActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🎨 Temas" Margin="14,0,0,0"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding OpenThemesCommand}"
                            ToolTip="Tipografía, colores, márgenes y fondos"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Salida:" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="220"
                              ItemsSource="{Binding Displays}"
                              SelectedItem="{Binding SelectedDisplay}"
                              DisplayMemberPath="Label"
                              VerticalAlignment="Center"/>
                    <Button Content="↻"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding RefreshDisplaysCommand}"
                            ToolTip="Actualizar pantallas"
                            Padding="9,6" Margin="6,0,14,0"/>
                    <Button Command="{Binding ToggleOutputCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                <Setter Property="Content" Value="🔴  Poner en vivo"/>
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProjecting}" Value="True">
                                        <Setter Property="Content" Value="Apagar salida  (Esc)"/>
                                        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ══ Zona central: biblioteca | slides | preview/live ══ -->
        <Grid Grid.Row="1" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="320" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: biblioteca + playlist -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="240"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Panel}">
                    <DockPanel>
                        <!-- Selector de pestaña -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,10,10,8">
                            <RadioButton Content="Canciones" Style="{StaticResource TabButton}"
                                         GroupName="LibraryTab"
                                         IsChecked="{Binding IsBibleTabActive, Converter={StaticResource InverseBool}}"
                                         Command="{Binding ShowSongsTabCommand}"/>
                            <RadioButton Content="Biblia" Style="{StaticResource TabButton}"
                                         GroupName="LibraryTab" Margin="4,0,0,0"
                                         IsChecked="{Binding IsBibleTabActive}"
                                         Command="{Binding ShowBibleTabCommand}"/>
                        </StackPanel>

                        <Grid>
                            <!-- ── Pestaña Canciones ── -->
                            <DockPanel Visibility="{Binding IsBibleTabActive, Converter={StaticResource InverseBoolToVis}}">
                                <DockPanel DockPanel.Dock="Top">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="0,0,10,8">
                                        <Button Content="📥" FontSize="11" Padding="7,4"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding ImportSongsCommand}"
                                                ToolTip="Importar canciones (.txt o ProPresenter .pro)"/>
                                        <Button Content="➕" FontSize="11" Padding="7,4" Margin="4,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding NewSongCommand}"
                                                ToolTip="Nueva canción"/>
                                        <Button Content="✏️" FontSize="11" Padding="7,4" Margin="4,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding EditSongCommand}"
                                                ToolTip="Editar canción"/>
                                        <Button Content="🗑" FontSize="11" Padding="7,4" Margin="4,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding DeleteSongCommand}"
                                                ToolTip="Eliminar canción"/>
                                    </StackPanel>
                                    <TextBlock Text="CANCIONES" Style="{StaticResource PanelTitle}" Margin="12,0,12,0"/>
                                </DockPanel>
                                <TextBox DockPanel.Dock="Top"
                                         Margin="12,0,12,8" Padding="8,6"
                                         Background="{StaticResource SurfaceAltBrush}"
                                         Foreground="White"
                                         BorderBrush="{StaticResource LineBrush}"
                                         CaretBrush="White"
                                         FontSize="13"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Buscar por título, artista o letra"/>
                                <TextBlock DockPanel.Dock="Bottom"
                                           Text="🖼 Medios (sprints 4–5)"
                                           FontSize="10" Foreground="{StaticResource FaintBrush}"
                                           Margin="12,4,12,10"/>
                                <ListBox x:Name="SongsList" ItemsSource="{Binding Songs}"
                                         SelectedItem="{Binding SelectedSong}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ToolTip="Doble clic proyecta · clic derecho: más opciones">
                                    <ListBox.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding ProjectFirstSlideCommand}"/>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding ProjectFirstSlideCommand}"/>
                                    </ListBox.InputBindings>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Setter Property="Tag"
                                                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="Editar canción (diseño)"
                                                                  Command="{Binding PlacementTarget.Tag.EditSongDesignForCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Editar como texto plano"
                                                                  Command="{Binding PlacementTarget.Tag.EditSongTextForCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Duplicar canción"
                                                                  Command="{Binding PlacementTarget.Tag.DuplicateSongCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Eliminar canción"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteSongForCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" Background="Transparent"
                                                                CornerRadius="4" Margin="6,1"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#20242F"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="13"
                                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}" FontSize="11"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- ── Pestaña Biblia ── -->
                            <DockPanel Visibility="{Binding IsBibleTabActive, Converter={StaticResource BoolToVis}}">
                                <!-- Versiones (hasta 2 tildadas a la vez, estilo BibleShow) -->
                                <DockPanel DockPanel.Dock="Top" Margin="12,0,12,4">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="📥" FontSize="11" Padding="7,4"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding ImportBibleCommand}"
                                                ToolTip="Importar Biblia (JSON o Zefania XML)"/>
                                        <Button Content="✏️" FontSize="11" Padding="7,4" Margin="4,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding RenameBibleVersionCommand}"
                                                ToolTip="Renombrar versión"/>
                                        <Button Content="🗑" FontSize="11" Padding="7,4" Margin="4,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding DeleteBibleVersionCommand}"
                                                ToolTip="Eliminar versión"/>
                                    </StackPanel>
                                    <TextBlock Text="VERSIONES — hasta 2 a la vez"
                                               FontSize="10" Foreground="{StaticResource FaintBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <Border DockPanel.Dock="Top" Margin="12,0,12,6"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                        CornerRadius="4" MaxHeight="98">
                                    <ListBox x:Name="VersionsList"
                                             ItemsSource="{Binding BibleVersionOptions}"
                                             SelectedItem="{Binding SelectedBibleVersionOption}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="8,3"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bd" Background="Transparent"
                                                                    CornerRadius="3"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#2C3040"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel>
                                                    <CheckBox IsChecked="{Binding IsSelected}"
                                                              VerticalAlignment="Center"
                                                              ToolTip="Activa esta versión para proyectar (la segunda se muestra debajo de la primera)"/>
                                                    <TextBlock Text="{Binding Info.Abbreviation}"
                                                               DockPanel.Dock="Right"
                                                               FontSize="10" Foreground="{StaticResource MutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Info.Name}"
                                                               FontSize="12" Foreground="White"
                                                               Margin="6,0,6,0"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Background="Transparent"
                                                               Cursor="Hand"
                                                               ToolTip="Clic: usar solo esta versión. La casilla agrega una segunda.">
                                                        <TextBlock.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectSoloVersionCommand, ElementName=VersionsList}"
                                                                          CommandParameter="{Binding}"/>
                                                        </TextBlock.InputBindings>
                                                    </TextBlock>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <TextBox DockPanel.Dock="Top"
                                         Margin="12,0,12,6" Padding="8,6"
                                         Background="{StaticResource SurfaceAltBrush}"
                                         Foreground="White"
                                         BorderBrush="{StaticResource LineBrush}"
                                         CaretBrush="White"
                                         FontSize="13"
                                         Text="{Binding BibleQuery, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Ej: Juan 3:16 · jn 3:16-18 · sal 23 · o una palabra. Enter proyecta el versículo.">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding ProjectReferenceCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <TextBlock DockPanel.Dock="Bottom"
                                           Text="{Binding BibleStatusText}"
                                           FontSize="10" Foreground="{StaticResource FaintBrush}"
                                           TextWrapping="Wrap"
                                           Margin="12,4,12,10"/>

                                <Grid>
                                    <!-- Lista de libros, en orden bíblico -->
                                    <ListBox ItemsSource="{Binding BibleBooksAvailable}"
                                             SelectedItem="{Binding SelectedBibleBook}"
                                             Visibility="{Binding ShowBooksList, Converter={StaticResource BoolToVis}}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,4"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bd" Background="Transparent"
                                                                    CornerRadius="4" Margin="6,0"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#20242F"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Capítulos del libro elegido, como grilla numérica -->
                                    <DockPanel Visibility="{Binding ShowChaptersView, Converter={StaticResource BoolToVis}}">
                                        <DockPanel DockPanel.Dock="Top" Margin="10,0,10,6">
                                            <Button DockPanel.Dock="Left" Content="◀ Libros"
                                                    Style="{StaticResource DarkButton}"
                                                    FontSize="11" Padding="8,4"
                                                    Command="{Binding BackToBooksCommand}"/>
                                            <TextBlock Text="{Binding ChaptersTitle}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="White"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <ScrollViewer x:Name="ChaptersScroll" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="ChaptersGrid"
                                                          ItemsSource="{Binding BibleChapters}"
                                                          Margin="8,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Number}"
                                                                Width="40" Height="32" Margin="2"
                                                                Padding="0" FontSize="12"
                                                                Command="{Binding DataContext.SelectChapterCommand, ElementName=ChaptersGrid}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                                            <Setter Property="BorderThickness" Value="0"/>
                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>

                                    <!-- Resultados de búsqueda por texto -->
                                    <ListBox x:Name="BibleResultsList"
                                         ItemsSource="{Binding BibleSearchResults}"
                                         Visibility="{Binding ShowBibleResults, Converter={StaticResource BoolToVis}}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ToolTip="Doble clic proyecta el versículo y carga el capítulo">
                                    <ListBox.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding ProjectBibleResultCommand}"
                                                      CommandParameter="{Binding SelectedItem, ElementName=BibleResultsList}"/>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding ProjectBibleResultCommand}"
                                                    CommandParameter="{Binding SelectedItem, ElementName=BibleResultsList}"/>
                                    </ListBox.InputBindings>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" Background="Transparent"
                                                                CornerRadius="4" Margin="6,1"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#20242F"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Reference}" FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Text}" FontSize="11"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap" MaxHeight="32"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Panel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="PLAYLIST DEL SERVICIO" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Style="{StaticResource PlaceholderText}"
                                   Text="El orden del culto — canciones, pasajes y medios — se arma acá. (sprint 6)"/>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Panel central: texto rápido + futura grilla de slides -->
            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="TEXTO RÁPIDO — anuncios al momento" Style="{StaticResource PanelTitle}"/>

                    <Grid Grid.Row="1" Margin="12,0,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Height="96"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding QuickText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource SurfaceAltBrush}"
                                 Foreground="White"
                                 BorderBrush="{StaticResource LineBrush}"
                                 CaretBrush="White"
                                 Padding="8,6" FontSize="14">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding GoLiveCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="Proyectar ▶&#10;(Ctrl+Enter)"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding GoLiveCommand}"
                                Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AVISO AL PIE — sobre todo lo demás"
                                   Style="{StaticResource PanelTitle}"/>
                        <TextBlock Grid.Column="1"
                                   Text="RESALTAR EN VIVO"
                                   Style="{StaticResource PanelTitle}"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="12,0,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OverlayText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource SurfaceAltBrush}"
                                     Foreground="White"
                                     BorderBrush="{StaticResource LineBrush}"
                                     CaretBrush="White"
                                     Padding="8,6" FontSize="14"
                                     VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ShowOverlayCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Content="Mostrar"
                                    Command="{Binding ShowOverlayCommand}"
                                    Margin="8,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2"
                                    Content="Quitar"
                                    Style="{StaticResource DarkButton}"
                                    Command="{Binding HideOverlayCommand}"
                                    Margin="6,0,0,0"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding HighlightText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource SurfaceAltBrush}"
                                     Foreground="White"
                                     BorderBrush="{StaticResource LineBrush}"
                                     CaretBrush="White"
                                     Padding="8,6" FontSize="14"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Escribí una palabra o frase y se pinta al instante sobre lo proyectado"/>
                            <Button Grid.Column="1"
                                    Content="Quitar"
                                    Style="{StaticResource DarkButton}"
                                    Command="{Binding ClearHighlightCommand}"
                                    Margin="6,0,0,0"/>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="4"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <TextBlock Text="Elegí una canción o buscá un pasaje bíblico (ej. &quot;Juan 3:16&quot;)&#10;y sus diapositivas aparecen acá.&#10;&#10;Clic en una diapositiva la proyecta · doble clic en la lista arranca desde la primera&#10;· flechas ←→ navegan en vivo.">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderText}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSlides}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="SlidesScroll" VerticalScrollBarVisibility="Auto" Padding="6">
                                <ItemsControl x:Name="SlideGrid" ItemsSource="{Binding Slides}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ProjectSlideCommand, ElementName=SlideGrid}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Tag="{Binding DataContext, ElementName=SlideGrid}"
                                                    ContextMenuOpening="SlideCard_ContextMenuOpening"
                                                    ToolTip="Clic: proyectar · Clic derecho: más opciones">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Editar canción (diseño)"
                                                                  Command="{Binding PlacementTarget.Tag.EditSongDesignCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Edición rápida (solo texto)"
                                                                  Command="{Binding PlacementTarget.Tag.QuickEditSlideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Editar como texto plano (canción)"
                                                                  Command="{Binding PlacementTarget.Tag.EditSongAsTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Copiar"
                                                                  Command="{Binding PlacementTarget.Tag.CopySlideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Pegar"
                                                                  Command="{Binding PlacementTarget.Tag.PasteSlideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Duplicar"
                                                                  Command="{Binding PlacementTarget.Tag.DuplicateSlideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Eliminar"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteSlideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="card" Width="180" Height="84" Margin="6"
                                                                CornerRadius="6" Background="#10141E"
                                                                BorderBrush="{StaticResource LineBrush}"
                                                                BorderThickness="1" Padding="10">
                                                            <DockPanel>
                                                                <TextBlock DockPanel.Dock="Top"
                                                                           Text="{Binding Label}"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource MutedBrush}"/>
                                                                <TextBlock Text="{Binding PreviewText}"
                                                                           FontSize="11" Foreground="White"
                                                                           TextWrapping="Wrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,5,0,0"/>
                                                            </DockPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="card" Property="Background" Value="#1A2030"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsPreviewed}" Value="True">
                                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                <Setter TargetName="card" Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsLive}" Value="True">
                                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource LiveBrush}"/>
                                                                <Setter TargetName="card" Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Panel derecho: preview y live -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="PREVIEW · SIGUIENTE" Style="{StaticResource PanelTitle}"/>
                        <Border Height="165" Margin="12,0,12,12"
                                Background="#0B0D12" CornerRadius="4">
                            <controls:ProjectedView Slide="{Binding PreviewSlide}"
                                                    BackgroundMedia="{Binding Projection.Background}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Panel}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9"
                                     Fill="{StaticResource LiveBrush}"
                                     VerticalAlignment="Center"
                                     Margin="12,1,0,0"/>
                            <TextBlock Text="LIVE · PROYECTADO" Style="{StaticResource PanelTitle}" Margin="7,10,12,8"/>
                        </StackPanel>
                        <Border Height="165" Margin="12,0,12,12"
                                Background="#0B0D12" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProjecting}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource LiveBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <controls:ProjectedView Slide="{Binding Projection.Slide}"
                                                    State="{Binding Projection.State}"
                                                    Overlay="{Binding Projection.Overlay}"
                                                    Highlight="{Binding Projection.Highlight}"
                                                    BackgroundMedia="{Binding Projection.Background}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ Barra de medios ══ -->
        <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="10,10,10,0" Height="108">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,10,2">
                        <Button Content="📥 Agregar" FontSize="11" Padding="8,4"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding ImportMediaCommand}"
                                ToolTip="Agregar imágenes o videos de fondo"/>
                        <Button Content="Sin fondo" FontSize="11" Padding="8,4" Margin="6,0,0,0"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding ClearBackgroundCommand}"
                                ToolTip="Quitar el fondo (queda negro/transparente)"/>
                    </StackPanel>
                    <TextBlock Text="FONDOS" Style="{StaticResource PanelTitle}" Margin="12,8,12,4"/>
                </DockPanel>

                <Grid>
                    <TextBlock Margin="16,0,16,8"
                               Text="Agregá imágenes o videos con 📥 y aplicalos con un clic.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderText}">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MediaItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ScrollViewer x:Name="MediaScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding MediaItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ApplyBackgroundCommand, ElementName=MediaScroll}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" Margin="6,2"
                                            Tag="{Binding DataContext, ElementName=MediaScroll}"
                                            ToolTip="{Binding Name}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Quitar de la biblioteca"
                                                          Command="{Binding PlacementTarget.Tag.DeleteMediaCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="card" Width="98" Height="56" CornerRadius="4"
                                                        Background="#10141E"
                                                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                                        Tag="{Binding DataContext, ElementName=MediaScroll}"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill"/>
                                                        <Border Background="#66000000" VerticalAlignment="Bottom" Padding="4,1">
                                                            <TextBlock Text="{Binding Name}" FontSize="9" Foreground="White"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                        <TextBlock Text="🎞" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="Collapsed" x:Name="videoIcon"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Video">
                                                        <Setter TargetName="videoIcon" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ══ Barra de estado ══ -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusText}"
                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                   Margin="14,8,14,10" TextWrapping="Wrap"/>
    </Grid>
</Window>
