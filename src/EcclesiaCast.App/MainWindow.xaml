<Window x:Class="EcclesiaCast.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcclesiaCast — Operador"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ProjectTestCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding HideOutputCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Barra superior ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,9">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="EcclesiaCast"
                           FontSize="17" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Salida:" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="220"
                              ItemsSource="{Binding Displays}"
                              SelectedItem="{Binding SelectedDisplay}"
                              DisplayMemberPath="Label"
                              VerticalAlignment="Center"/>
                    <Button Content="↻"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding RefreshDisplaysCommand}"
                            ToolTip="Actualizar pantallas"
                            Padding="9,6" Margin="6,0,14,0"/>
                    <Button Content="Proyectar prueba  (F1)"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ProjectTestCommand}"/>
                    <Button Content="Ocultar  (Esc)"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding HideOutputCommand}"
                            Margin="8,0,0,0"/>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ══ Zona central: biblioteca | slides | preview/live ══ -->
        <Grid Grid.Row="1" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="320" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: biblioteca + playlist -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="240"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Panel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="BIBLIOTECA" Style="{StaticResource PanelTitle}"/>
                        <TextBox DockPanel.Dock="Top"
                                 Margin="12,0,12,8" Padding="8,6"
                                 Background="{StaticResource SurfaceAltBrush}"
                                 Foreground="{StaticResource FaintBrush}"
                                 BorderBrush="{StaticResource LineBrush}"
                                 CaretBrush="White"
                                 Text="Buscar…  (sprint 2)"
                                 IsEnabled="False"/>
                        <TextBlock Style="{StaticResource PlaceholderText}"
                                   Text="🎵 Canciones (sprint 2)&#10;&#10;📖 Biblia (sprint 3)&#10;&#10;🖼 Medios (sprints 4–5)"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Panel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="PLAYLIST DEL SERVICIO" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Style="{StaticResource PlaceholderText}"
                                   Text="El orden del culto — canciones, pasajes y medios — se arma acá. (sprint 6)"/>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Panel central: grilla de slides -->
            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SLIDES" Style="{StaticResource PanelTitle}"/>
                    <TextBlock Style="{StaticResource PlaceholderText}"
                               Text="Las diapositivas de la canción o el pasaje seleccionado aparecen acá,&#10;listas para proyectar con un clic o con las flechas del teclado.&#10;&#10;(sprint 1: texto rápido · sprint 2: canciones · sprint 3: Biblia)"/>
                </DockPanel>
            </Border>

            <!-- Panel derecho: preview y live -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="PREVIEW · SIGUIENTE" Style="{StaticResource PanelTitle}"/>
                        <Border Height="165" Margin="12,0,12,12"
                                Background="#0B0D12" CornerRadius="4">
                            <TextBlock Style="{StaticResource PlaceholderText}"
                                       Text="Lo que se prepara,&#10;antes de salir en vivo. (sprint 1)"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Panel}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9"
                                     Fill="{StaticResource LiveBrush}"
                                     VerticalAlignment="Center"
                                     Margin="12,1,0,0"/>
                            <TextBlock Text="LIVE · PROYECTADO" Style="{StaticResource PanelTitle}" Margin="7,10,12,8"/>
                        </StackPanel>
                        <Border Height="165" Margin="12,0,12,12"
                                Background="#0B0D12" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProjecting}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource LiveBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding LiveLabel}"
                                       Style="{StaticResource PlaceholderText}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ Barra de medios ══ -->
        <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="10,10,10,0" Height="86">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="FONDOS" Style="{StaticResource PanelTitle}" Margin="12,8,12,4"/>
                <TextBlock Style="{StaticResource PlaceholderText}" Margin="16,0,16,8"
                           Text="Miniaturas de imágenes y videos de fondo, aplicables con un clic. (sprints 4–5)"/>
            </DockPanel>
        </Border>

        <!-- ══ Barra de estado ══ -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusText}"
                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                   Margin="14,8,14,10" TextWrapping="Wrap"/>
    </Grid>
</Window>
