<UserControl x:Class="EcclesiaCast.App.Controls.SlideView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Renders at a fixed virtual 1920×1080 and scales uniformly, so the
         projector output and the small preview boxes look identical. -->
    <Viewbox Stretch="Uniform">
        <Grid x:Name="RootCanvas" Width="1920" Height="1080" Background="#10141E">

            <!-- Fondo: imagen opcional + oscurecedor -->
            <Image x:Name="BackgroundImage" Stretch="UniformToFill" Visibility="Collapsed"/>
            <Rectangle x:Name="DimLayer" Fill="Black" Opacity="0" IsHitTestVisible="False"/>

            <!-- Capa de texto -->
            <Grid x:Name="TextLayer" Margin="110,80">
                <StackPanel x:Name="TextStack" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="MainText"
                               FontFamily="Segoe UI"
                               FontSize="92" FontWeight="SemiBold"
                               Foreground="White"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <!-- Segunda versión bíblica, cuando hay dos seleccionadas -->
                    <TextBlock x:Name="SecondaryText"
                               FontFamily="Segoe UI"
                               FontSize="58" FontStyle="Italic"
                               Foreground="#C9D4E8"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,50,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
                <TextBlock x:Name="CaptionText"
                           FontFamily="Segoe UI"
                           FontSize="40"
                           Foreground="#B9C6DE"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Capa de logo -->
            <Grid x:Name="LogoLayer" Background="#10141E" Visibility="Collapsed">
                <TextBlock Text="EcclesiaCast"
                           FontFamily="Segoe UI"
                           FontSize="120" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Capa de negro -->
            <Rectangle x:Name="BlackLayer" Fill="Black" Opacity="0" IsHitTestVisible="False"/>

            <!-- Aviso al pie: por encima de todo, incluso del negro -->
            <Border x:Name="OverlayLayer"
                    VerticalAlignment="Bottom"
                    Background="#E0000000"
                    BorderBrush="#2F63C9"
                    BorderThickness="0,4,0,0"
                    Padding="70,30"
                    Visibility="Collapsed">
                <TextBlock x:Name="OverlayText"
                           FontFamily="Segoe UI"
                           FontSize="54" FontWeight="Medium"
                           Foreground="White"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Border>

        </Grid>
    </Viewbox>
</UserControl>
