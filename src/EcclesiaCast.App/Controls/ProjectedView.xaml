<UserControl x:Class="EcclesiaCast.App.Controls.ProjectedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EcclesiaCast.App.Controls">
    <Grid Background="Black" ClipToBounds="True">
        <!-- Capa de fondo global (imagen; el video llega después) -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Visibility="Collapsed"/>

        <!-- Texto, estados (Clear/Black/Logo), aviso al pie y resaltado -->
        <controls:SlideView x:Name="SlideRenderer"/>
    </Grid>
</UserControl>
